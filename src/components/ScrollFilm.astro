---
// Bean-to-cup scroll-film: one continuous scene, smoothly scrubbed by scroll
// (pinned + eased rAF, De Boe-stijl). Ends on the real owner pouring, held long.
import { SITE } from "../data/site";

// Per-stage annotations. `at` = film progress, `side`/`top` place the note
// beside the subject; a dashed leader line points inward at it.
const caps = [
  { at: 0.16, num: "01", title: "In de molen", text: "Op het moment zelf gemalen, nooit van tevoren.", side: "right", top: "32%" },
  { at: 0.34, num: "02", title: "Vers gemalen", text: "Fijn, geurig en klaar voor de shot.", side: "left", top: "46%" },
  { at: 0.52, num: "03", title: "Aangedrukt", text: "Strak getampt voor een gelijke extractie.", side: "right", top: "54%" },
  { at: 0.7, num: "04", title: "Espresso", text: "Op de seconde getrokken, met goudgele crema.", side: "left", top: "44%" },
  { at: 0.88, num: "05", title: "Met de hand", text: "Door Marcus zelf ingeschonken.", side: "right", top: "40%" },
];
---

<section class="film" data-film aria-label="Van boon tot kop">
  <div class="film__sticky">
    <canvas class="film__canvas" role="img" aria-label="Scroll-film: van de koffieboon tot in het kopje"></canvas>
    <div class="film__scrim" aria-hidden="true"></div>

    <!-- intro (before scroll) -->
    <div class="film__intro">
      <p class="film__eyebrow">Bellamypark &middot; Vlissingen</p>
      <h1 class="film__title">{SITE.wordmark}</h1>
      <p class="film__sub">Van de boon tot in jouw kop</p>
    </div>

    <!-- per-stage annotations, beside the subject with a leader line -->
    <div class="film__captions" aria-hidden="true">
      {
        caps.map((c) => (
          <figure class="film__cap" data-at={c.at} data-side={c.side} style={`top:${c.top}`}>
            <div class="film__cap-body">
              <span class="film__cap-num">{c.num}</span>
              <h2 class="film__cap-title">{c.title}</h2>
              <p class="film__cap-text">{c.text}</p>
            </div>
            <span class="film__cap-line"></span>
          </figure>
        ))
      }
    </div>

    <!-- chapter rail (welke etappe + hoe ver) -->
    <nav class="film__rail" aria-label="Hoofdstukken">
      {
        caps.map((c, i) => (
          <button class="film__dot" type="button" data-dot={i} aria-label={`Naar ${c.title}`}>
            <span class="film__dot-num">{c.num}</span>
          </button>
        ))
      }
    </nav>

    <!-- final cta -->
    <div class="film__cta">
      <p class="film__eyebrow text-saffron">{SITE.tagline}</p>
      <h2 class="film__cta-title">In jouw kop</h2>
      <p class="film__cta-text">Alles huisgemaakt, met een Marokkaanse ziel. Kom proeven aan het Bellamypark.</p>
      <div class="film__cta-actions">
        <a href="/menu" class="press rounded-full bg-cream px-7 py-3.5 text-sm font-semibold text-ink">Bekijk de kaart</a>
        <a href="/reserveren" class="press rounded-full border border-cream/30 px-7 py-3.5 text-sm font-semibold text-cream">Reserveren</a>
      </div>
    </div>

    <div class="film__progress" aria-hidden="true"><span></span></div>
    <div class="film__hint" aria-hidden="true">
      <span>Scroll</span>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <div class="film__loader">
      <div class="film__loader-word">{SITE.wordmark}</div>
      <div class="film__loader-bar"><span></span></div>
      <div class="film__loader-pct">0%</div>
    </div>
  </div>
</section>

<!-- Static fallback (reduced motion / no frames) -->
<section class="film-fallback">
  <img src="/img/signature.webp" alt="Koffie van Marcus" />
  <div class="film-fallback__text">
    <p class="film__eyebrow text-saffron">Bellamypark &middot; Vlissingen</p>
    <h1 class="film__title text-cream">{SITE.wordmark}</h1>
    <p class="mt-3 text-cream/80">Van de boon tot in jouw kop, alles huisgemaakt.</p>
  </div>
</section>

<style>
  .film {
    display: none;
    position: relative;
    background: var(--color-ink);
  }
  .film__sticky {
    position: relative;
    height: 100svh;
    width: 100%;
    overflow: hidden;
    background: var(--color-ink);
  }
  .film__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .film__scrim {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(120% 80% at 50% 30%, transparent 45%, rgba(20, 11, 5, 0.55) 100%),
      linear-gradient(to top, rgba(20, 11, 5, 0.78) 0%, transparent 36%, transparent 60%, rgba(20, 11, 5, 0.45) 100%);
  }

  .film__intro {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
    color: var(--color-cream);
    will-change: opacity;
  }
  .film__eyebrow {
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.72rem;
    color: var(--color-saffron);
  }
  .film__title {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 0.86;
    letter-spacing: -0.04em;
    font-size: clamp(4rem, 17vw, 15rem);
    margin-top: 0.5rem;
    text-shadow: 0 4px 60px rgba(20, 11, 5, 0.6);
  }
  .film__sub {
    margin-top: 0.75rem;
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    color: rgba(244, 236, 219, 0.85);
  }

  .film__captions {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .film__cap {
    position: absolute;
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    opacity: 0;
    margin: 0;
    color: var(--color-cream);
    will-change: opacity;
    transform: translateY(-50%);
  }
  .film__cap[data-side="left"] {
    left: clamp(1.25rem, 6vw, 5rem);
  }
  .film__cap[data-side="right"] {
    right: clamp(1.25rem, 6vw, 5rem);
    flex-direction: row-reverse;
    text-align: right;
  }
  .film__cap-body {
    max-width: min(21rem, 64vw);
  }
  .film__cap-num {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-saffron);
    letter-spacing: 0.12em;
  }
  .film__cap-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.9rem, 4.6vw, 3.6rem);
    line-height: 0.98;
    margin-top: 0.2rem;
    text-shadow: 0 2px 30px rgba(20, 11, 5, 0.7);
  }
  .film__cap-text {
    margin-top: 0.55rem;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.45;
    color: rgba(244, 236, 219, 0.82);
    text-shadow: 0 1px 14px rgba(20, 11, 5, 0.7);
  }
  .film__cap-line {
    flex: 0 0 auto;
    align-self: center;
    height: 1px;
    width: clamp(2.5rem, 13vw, 12rem);
    border-top: 1px dashed rgba(244, 236, 219, 0.55);
    position: relative;
  }
  .film__cap-line::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 1px solid var(--color-saffron);
    background: rgba(224, 165, 46, 0.3);
    transform: translateY(-50%);
    box-shadow: 0 0 14px rgba(224, 165, 46, 0.5);
  }
  .film__cap[data-side="left"] .film__cap-line::after { right: -4px; }
  .film__cap[data-side="right"] .film__cap-line::after { left: -4px; }

  @media (max-width: 820px) {
    .film__cap { gap: 0.55rem; }
    .film__cap[data-side="left"] { left: 1.1rem; }
    .film__cap[data-side="right"] { right: 1.1rem; }
    .film__cap-body { max-width: 66vw; }
    .film__cap-line { width: clamp(1.25rem, 7vw, 3rem); }
  }

  .film__rail {
    position: absolute;
    right: clamp(0.9rem, 2vw, 1.7rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 6;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .film__dot {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 2px 0;
    background: none;
    border: 0;
    cursor: pointer;
  }
  .film__dot::after {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: rgba(244, 236, 219, 0.3);
    transition: height 0.45s cubic-bezier(0.16, 1, 0.3, 1), background 0.45s;
  }
  .film__dot.is-active::after {
    background: var(--color-saffron);
    height: 24px;
  }
  .film__dot-num {
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: rgba(244, 236, 219, 0.55);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .film__dot.is-active .film__dot-num,
  .film__dot:hover .film__dot-num {
    opacity: 1;
  }
  @media (max-width: 820px) {
    .film__rail { display: none; }
  }

  .film__cta {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
    opacity: 0;
    color: var(--color-cream);
    will-change: opacity;
  }
  .film__cta-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 0.9;
    margin-top: 0.4rem;
  }
  .film__cta-text {
    margin-top: 1rem;
    max-width: 32rem;
    color: rgba(244, 236, 219, 0.85);
  }
  .film__cta-actions {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .film__progress {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 3px;
    width: 100%;
    background: rgba(244, 236, 219, 0.12);
  }
  .film__progress span {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: var(--color-saffron);
  }

  .film__hint {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(244, 236, 219, 0.6);
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 0.66rem;
    transition: opacity 0.4s ease;
  }
  .film__hint svg {
    animation: filmbounce 1.6s ease-in-out infinite;
  }
  @keyframes filmbounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  .film__loader {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    background: var(--color-ink);
    z-index: 5;
    transition: opacity 0.6s ease;
  }
  .film__loader.is-done {
    opacity: 0;
    pointer-events: none;
  }
  .film__loader-word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3rem, 11vw, 7rem);
    letter-spacing: -0.04em;
    color: rgba(244, 236, 219, 0.92);
  }
  .film__loader-bar {
    width: min(220px, 60vw);
    height: 2px;
    background: rgba(244, 236, 219, 0.15);
    overflow: hidden;
  }
  .film__loader-bar span {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: var(--color-saffron);
    transition: transform 0.3s ease;
  }
  .film__loader-pct {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(244, 236, 219, 0.5);
  }

  .film-fallback {
    position: relative;
    display: block;
    height: 100svh;
    overflow: hidden;
    background: var(--color-ink);
  }
  .film-fallback img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.7;
  }
  .film-fallback__text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
  }
  .film.is-on + .film-fallback {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .film { display: none !important; }
    .film-fallback { display: block; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function setupFilm() {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const film = document.querySelector<HTMLElement>("[data-film]");
    const fallback = document.querySelector<HTMLElement>(".film-fallback");
    if (!film) return;
    if (reduced) { film.style.display = "none"; if (fallback) fallback.style.display = "block"; return; }

    const sticky = film.querySelector<HTMLElement>(".film__sticky");
    const canvas = film.querySelector<HTMLCanvasElement>(".film__canvas");
    if (!sticky || !canvas) return;
    const ctx = canvas.getContext("2d");

    film.style.display = "block";
    film.classList.add("is-on");
    if (fallback) fallback.style.display = "none";

    const loaderEl = film.querySelector<HTMLElement>(".film__loader");
    const barEl = film.querySelector<HTMLElement>(".film__loader-bar span");
    const pctEl = film.querySelector<HTMLElement>(".film__loader-pct");
    const progEl = film.querySelector<HTMLElement>(".film__progress span");
    const hintEl = film.querySelector<HTMLElement>(".film__hint");
    const introEl = film.querySelector<HTMLElement>(".film__intro");
    const ctaEl = film.querySelector<HTMLElement>(".film__cta");
    const caps = Array.from(film.querySelectorAll<HTMLElement>(".film__cap"));

    const images: HTMLImageElement[] = [];
    let count = 0;
    let cover = { dw: 0, dh: 0, dx: 0, dy: 0 };
    let renderFP = 0;
    const small = window.matchMedia("(max-width: 820px)").matches;
    const dpr = Math.min(window.devicePixelRatio || 1, small ? 2 : 1.5);

    const FILM_VH = 7;   // schermen scroll om de hele film door te scrubben
    const HOLD_VH = 1.7; // het laatste shot (Marcus) langer vasthouden
    const filmFrac = FILM_VH / (FILM_VH + HOLD_VH);

    function computeCover() {
      const img = images[0];
      const cw = canvas.width, ch = canvas.height;
      if (!img || !img.naturalWidth) { cover = { dw: cw, dh: ch, dx: 0, dy: 0 }; return; }
      const ir = img.naturalWidth / img.naturalHeight, cr = cw / ch;
      if (cr > ir) cover = { dw: cw, dh: cw / ir, dx: 0, dy: (ch - cw / ir) / 2 };
      else cover = { dw: ch * ir, dh: ch, dx: (cw - ch * ir) / 2, dy: 0 };
    }
    function paint(img: HTMLImageElement, alpha: number) {
      if (!ctx || !img || !img.naturalWidth) return;
      ctx.globalAlpha = alpha;
      ctx.drawImage(img, cover.dx, cover.dy, cover.dw, cover.dh);
      ctx.globalAlpha = 1;
    }
    function draw(f: number) {
      if (!ctx) return;
      const i0 = Math.max(0, Math.min(count - 1, Math.floor(f)));
      const i1 = Math.min(count - 1, i0 + 1);
      const t = f - i0;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      paint(images[i0], 1);
      if (i1 !== i0 && t > 0.001) paint(images[i1], t);
    }
    function resize() {
      const cw = sticky.clientWidth, chh = sticky.clientHeight;
      canvas.width = Math.round(cw * dpr); canvas.height = Math.round(chh * dpr);
      canvas.style.width = cw + "px"; canvas.style.height = chh + "px";
      computeCover();
      draw(renderFP * (count - 1));
    }

    function build() {
      resize();
      draw(0);
      const total = Math.round(window.innerHeight * (FILM_VH + HOLD_VH));
      let targetFP = 0, lastFp = -1, activeDot = -1;
      const dots = Array.from(film.querySelectorAll<HTMLElement>(".film__dot"));
      const ats = caps.map((c) => parseFloat(c.dataset.at || "0"));
      // Pin the stage; onUpdate only delivers the target progress (no scrub/snap),
      // a rAF loop eases the shown frame toward it for a smooth, clean scrub.
      const st = ScrollTrigger.create({
        trigger: film, start: "top top", end: "+=" + total,
        pin: sticky, anticipatePin: 1, invalidateOnRefresh: true,
        onUpdate: (self) => { targetFP = Math.min(1, self.progress / filmFrac); },
      });
      // Klik op een stip = spring naar dat hoofdstuk.
      const lenis = (window as any).__lenis;
      dots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
          const y = st.start + ats[i] * filmFrac * (st.end - st.start);
          if (lenis) lenis.scrollTo(y, { duration: 1 });
          else window.scrollTo({ top: y, behavior: "smooth" });
        });
      });
      gsap.ticker.add(() => {
        renderFP += (targetFP - renderFP) * 0.1;
        if (Math.abs(targetFP - renderFP) < 0.0004) renderFP = targetFP;
        if (Math.abs(renderFP - lastFp) < 0.0005) return;
        lastFp = renderFP;
        const fp = renderFP;
        draw(fp * (count - 1));
        if (progEl) progEl.style.transform = "scaleX(" + fp + ")";
        if (introEl) introEl.style.opacity = String(Math.max(0, 1 - fp / 0.05));
        if (ctaEl) ctaEl.style.opacity = String(Math.max(0, Math.min(1, (fp - 0.93) / 0.045)));
        if (hintEl) hintEl.style.opacity = fp > 0.02 ? "0" : "1";
        caps.forEach((cap) => {
          const at = parseFloat(cap.dataset.at || "-1");
          const d = Math.abs(fp - at);
          cap.style.opacity = String(d > 0.07 ? 0 : 1 - d / 0.07);
        });
        // actieve hoofdstuk-stip = dichtstbijzijnde etappe
        let a = 0;
        for (let i = 1; i < ats.length; i++) if (Math.abs(fp - ats[i]) < Math.abs(fp - ats[a])) a = i;
        if (a !== activeDot) { activeDot = a; dots.forEach((d, i) => d.classList.toggle("is-active", i === a)); }
      });
      window.addEventListener("resize", resize);
      ScrollTrigger.refresh();
    }

    fetch("/film/frames/manifest.json")
      .then((r) => r.json())
      .then((m) => {
        count = m.count;
        const pad = (n: number) => String(n).padStart(4, "0");
        let loaded = 0, built = false;
        const ready = Math.min(count, 30);
        const done = () => {
          loaded++;
          const frac = Math.min(1, loaded / ready);
          if (barEl) (barEl as HTMLElement).style.transform = "scaleX(" + frac + ")";
          if (pctEl) pctEl.textContent = Math.round(frac * 100) + "%";
          if (!built && loaded >= ready) { built = true; if (loaderEl) loaderEl.classList.add("is-done"); build(); }
        };
        for (let i = 1; i <= count; i++) {
          const img = new Image();
          img.decoding = "async";
          img.onload = done; img.onerror = done;
          img.src = "/film/frames/f" + pad(i) + ".jpg";
          images[i - 1] = img;
        }
      })
      .catch(() => { if (film) film.style.display = "none"; if (fallback) fallback.style.display = "block"; });
  }

  if (document.readyState !== "loading") setupFilm();
  else document.addEventListener("DOMContentLoaded", setupFilm);
</script>
