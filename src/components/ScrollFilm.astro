---
// Bean-to-cup scroll-film: one continuous scene scrubbed by scroll.
// Frames come from /film/frames (keyframes now, Kling-interpolated later).
import { SITE } from "../data/site";

// Per-stage annotations. `at` = scroll progress, `side`/`top` place the note
// beside the subject; a dashed leader line points inward at it.
const caps = [
  { at: 0.16, num: "01", title: "In de molen", text: "Op het moment zelf gemalen, nooit van tevoren.", side: "right", top: "32%" },
  { at: 0.34, num: "02", title: "Vers gemalen", text: "Fijn, geurig en klaar voor de shot.", side: "left", top: "46%" },
  { at: 0.52, num: "03", title: "Aangedrukt", text: "Strak getampt voor een gelijke extractie.", side: "right", top: "54%" },
  { at: 0.7, num: "04", title: "Espresso", text: "Op de seconde getrokken, met goudgele crema.", side: "left", top: "44%" },
  { at: 0.86, num: "05", title: "Met de hand", text: "Melk erin, latte-art eruit. Met zorg geschonken.", side: "right", top: "40%" },
];
---

<section class="film" data-film aria-label="Van boon tot kop">
  <div class="film__sticky">
    <canvas class="film__canvas" role="img" aria-label="Scroll-film: van de koffieboon tot in het kopje"></canvas>
    <div class="film__scrim" aria-hidden="true"></div>

    <!-- intro (before scroll) -->
    <div class="film__intro">
      <p class="film__eyebrow">Bellamypark &middot; Vlissingen</p>
      <h1 class="film__title">{SITE.wordmark}</h1>
      <p class="film__sub">Van de boon tot in jouw kop</p>
    </div>

    <!-- per-stage annotations, beside the subject with a leader line -->
    <div class="film__captions" aria-hidden="true">
      {
        caps.map((c) => (
          <figure class="film__cap" data-at={c.at} data-side={c.side} style={`top:${c.top}`}>
            <div class="film__cap-body">
              <span class="film__cap-num">{c.num}</span>
              <h2 class="film__cap-title">{c.title}</h2>
              <p class="film__cap-text">{c.text}</p>
            </div>
            <span class="film__cap-line"></span>
          </figure>
        ))
      }
    </div>

    <!-- final cta -->
    <div class="film__cta">
      <p class="film__eyebrow text-saffron">{SITE.tagline}</p>
      <h2 class="film__cta-title">In jouw kop</h2>
      <p class="film__cta-text">Alles huisgemaakt, met een Marokkaanse ziel. Kom proeven aan het Bellamypark.</p>
      <div class="film__cta-actions">
        <a href="/menu" class="press rounded-full bg-cream px-7 py-3.5 text-sm font-semibold text-ink">Bekijk de kaart</a>
        <a href="/reserveren" class="press rounded-full border border-cream/30 px-7 py-3.5 text-sm font-semibold text-cream">Reserveren</a>
      </div>
    </div>

    <div class="film__progress" aria-hidden="true"><span></span></div>
    <div class="film__hint" aria-hidden="true">
      <span>Scroll</span>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <button id="filmSound" class="film__sound press" type="button" aria-label="Geluid aanzetten" aria-pressed="false">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M11 5 6 9H3v6h3l5 4V5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        <path class="snd-wave" d="M16 9a4 4 0 0 1 0 6M18.6 6.4a8 8 0 0 1 0 11.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <line class="snd-mute" x1="16.5" y1="8" x2="22" y2="16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </button>

    <div class="film__loader">
      <div class="film__loader-word">{SITE.wordmark}</div>
      <div class="film__loader-bar"><span></span></div>
      <div class="film__loader-pct">0%</div>
    </div>
  </div>
</section>

<!-- Static fallback (reduced motion / no frames) -->
<section class="film-fallback">
  <img src="/img/drink-hero.webp" alt="Koffie van Marcus" />
  <div class="film-fallback__text">
    <p class="film__eyebrow text-saffron">Bellamypark &middot; Vlissingen</p>
    <h1 class="film__title text-cream">{SITE.wordmark}</h1>
    <p class="mt-3 text-cream/80">Van de boon tot in jouw kop, alles huisgemaakt.</p>
  </div>
</section>

<style>
  .film {
    display: none;
    position: relative;
    background: var(--color-ink);
  }
  .film__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    width: 100%;
    overflow: hidden;
    background: var(--color-ink);
  }
  .film__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .film__scrim {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(120% 80% at 50% 30%, transparent 45%, rgba(20, 11, 5, 0.55) 100%),
      linear-gradient(to top, rgba(20, 11, 5, 0.78) 0%, transparent 36%, transparent 60%, rgba(20, 11, 5, 0.45) 100%);
  }

  .film__intro {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
    color: var(--color-cream);
    will-change: opacity;
  }
  .film__eyebrow {
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.72rem;
    color: var(--color-saffron);
  }
  .film__title {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 0.86;
    letter-spacing: -0.04em;
    font-size: clamp(4rem, 17vw, 15rem);
    margin-top: 0.5rem;
    text-shadow: 0 4px 60px rgba(20, 11, 5, 0.6);
  }
  .film__sub {
    margin-top: 0.75rem;
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    color: rgba(244, 236, 219, 0.85);
  }

  .film__captions {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  /* a note sits beside the subject; a dashed leader line points inward at it */
  .film__cap {
    position: absolute;
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    opacity: 0;
    margin: 0;
    color: var(--color-cream);
    will-change: opacity;
    transform: translateY(-50%);
  }
  .film__cap[data-side="left"] {
    left: clamp(1.25rem, 6vw, 5rem);
  }
  .film__cap[data-side="right"] {
    right: clamp(1.25rem, 6vw, 5rem);
    flex-direction: row-reverse;
    text-align: right;
  }
  .film__cap-body {
    max-width: min(21rem, 64vw);
  }
  .film__cap-num {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-saffron);
    letter-spacing: 0.12em;
  }
  .film__cap-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.9rem, 4.6vw, 3.6rem);
    line-height: 0.98;
    margin-top: 0.2rem;
    text-shadow: 0 2px 30px rgba(20, 11, 5, 0.7);
  }
  .film__cap-text {
    margin-top: 0.55rem;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.45;
    color: rgba(244, 236, 219, 0.82);
    text-shadow: 0 1px 14px rgba(20, 11, 5, 0.7);
  }
  .film__cap-line {
    flex: 0 0 auto;
    align-self: center;
    height: 1px;
    width: clamp(2.5rem, 13vw, 12rem);
    border-top: 1px dashed rgba(244, 236, 219, 0.55);
    position: relative;
  }
  .film__cap-line::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 1px solid var(--color-saffron);
    background: rgba(224, 165, 46, 0.3);
    transform: translateY(-50%);
    box-shadow: 0 0 14px rgba(224, 165, 46, 0.5);
  }
  .film__cap[data-side="left"] .film__cap-line::after { right: -4px; }
  .film__cap[data-side="right"] .film__cap-line::after { left: -4px; }

  @media (max-width: 820px) {
    .film__cap { gap: 0.55rem; }
    .film__cap[data-side="left"] { left: 1.1rem; }
    .film__cap[data-side="right"] { right: 1.1rem; }
    .film__cap-body { max-width: 66vw; }
    .film__cap-line { width: clamp(1.25rem, 7vw, 3rem); }
  }

  .film__cta {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
    opacity: 0;
    color: var(--color-cream);
    will-change: opacity;
  }
  .film__cta-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 0.9;
    margin-top: 0.4rem;
  }
  .film__cta-text {
    margin-top: 1rem;
    max-width: 32rem;
    color: rgba(244, 236, 219, 0.85);
  }
  .film__cta-actions {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .film__progress {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 3px;
    width: 100%;
    background: rgba(244, 236, 219, 0.12);
  }
  .film__progress span {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: var(--color-saffron);
  }

  .film__hint {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(244, 236, 219, 0.6);
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 0.66rem;
    transition: opacity 0.4s ease;
  }
  .film__hint svg {
    animation: filmbounce 1.6s ease-in-out infinite;
  }
  @keyframes filmbounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  .film__sound {
    position: absolute;
    bottom: 1.4rem;
    left: 1.4rem;
    z-index: 6;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid rgba(244, 236, 219, 0.25);
    background: rgba(20, 11, 5, 0.35);
    color: rgba(244, 236, 219, 0.8);
    backdrop-filter: blur(4px);
    transition: color 0.3s, border-color 0.3s, background 0.3s;
  }
  .film__sound:hover {
    color: var(--color-cream);
    border-color: rgba(244, 236, 219, 0.5);
  }
  .film__sound.is-on {
    color: var(--color-saffron);
    border-color: rgba(224, 165, 46, 0.5);
  }
  .film__sound .snd-wave { opacity: 0; transition: opacity 0.3s; }
  .film__sound.is-on .snd-wave { opacity: 1; }
  .film__sound .snd-mute { opacity: 1; transition: opacity 0.3s; }
  .film__sound.is-on .snd-mute { opacity: 0; }

  .film__loader {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    background: var(--color-ink);
    z-index: 5;
    transition: opacity 0.6s ease;
  }
  .film__loader.is-done {
    opacity: 0;
    pointer-events: none;
  }
  .film__loader-word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3rem, 11vw, 7rem);
    letter-spacing: -0.04em;
    color: rgba(244, 236, 219, 0.92);
  }
  .film__loader-bar {
    width: min(220px, 60vw);
    height: 2px;
    background: rgba(244, 236, 219, 0.15);
    overflow: hidden;
  }
  .film__loader-bar span {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: var(--color-saffron);
    transition: transform 0.3s ease;
  }
  .film__loader-pct {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(244, 236, 219, 0.5);
  }

  /* Static fallback */
  .film-fallback {
    position: relative;
    display: block;
    height: 100svh;
    overflow: hidden;
    background: var(--color-ink);
  }
  .film-fallback img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.7;
  }
  .film-fallback__text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
  }
  .film.is-on + .film-fallback {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .film { display: none !important; }
    .film-fallback { display: block; }
  }
</style>

<script>
  import { gsap } from "gsap";

  // Step engine: one chapter per scroll gesture. You cannot fly past to the
  // end in one go; each gesture plays the motion to the next stop and locks.
  const STOPS = [0, 0.16, 0.34, 0.52, 0.7, 0.86, 1];

  function setupFilm() {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const film = document.querySelector<HTMLElement>("[data-film]");
    const fallback = document.querySelector<HTMLElement>(".film-fallback");
    if (!film) return;
    if (reduced) { film.style.display = "none"; if (fallback) fallback.style.display = "block"; return; }

    const sticky = film.querySelector<HTMLElement>(".film__sticky");
    const canvas = film.querySelector<HTMLCanvasElement>(".film__canvas");
    if (!sticky || !canvas) return;
    const ctx = canvas.getContext("2d");

    film.style.display = "block";
    film.classList.add("is-on");
    if (fallback) fallback.style.display = "none";
    document.documentElement.style.overflow = "hidden"; // lock until the film engages

    const loaderEl = film.querySelector<HTMLElement>(".film__loader");
    const barEl = film.querySelector<HTMLElement>(".film__loader-bar span");
    const pctEl = film.querySelector<HTMLElement>(".film__loader-pct");
    const progEl = film.querySelector<HTMLElement>(".film__progress span");
    const hintEl = film.querySelector<HTMLElement>(".film__hint");
    const introEl = film.querySelector<HTMLElement>(".film__intro");
    const ctaEl = film.querySelector<HTMLElement>(".film__cta");
    const caps = Array.from(film.querySelectorAll<HTMLElement>(".film__cap"));

    const images: HTMLImageElement[] = [];
    let count = 0;
    let fp = 0;
    const small = window.matchMedia("(max-width: 820px)").matches;
    const dpr = Math.min(window.devicePixelRatio || 1, small ? 2 : 1.5);
    let cover = { dw: 0, dh: 0, dx: 0, dy: 0 };

    function computeCover() {
      const img = images[0];
      const cw = canvas.width, ch = canvas.height;
      if (!img || !img.naturalWidth) { cover = { dw: cw, dh: ch, dx: 0, dy: 0 }; return; }
      const ir = img.naturalWidth / img.naturalHeight, cr = cw / ch;
      if (cr > ir) cover = { dw: cw, dh: cw / ir, dx: 0, dy: (ch - cw / ir) / 2 };
      else cover = { dw: ch * ir, dh: ch, dx: (cw - ch * ir) / 2, dy: 0 };
    }
    function paint(img: HTMLImageElement, alpha: number) {
      if (!ctx || !img || !img.naturalWidth) return;
      ctx.globalAlpha = alpha;
      ctx.drawImage(img, cover.dx, cover.dy, cover.dw, cover.dh);
      ctx.globalAlpha = 1;
    }
    function draw(f: number) {
      if (!ctx) return;
      const i0 = Math.max(0, Math.min(count - 1, Math.floor(f)));
      const i1 = Math.min(count - 1, i0 + 1);
      const t = f - i0;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      paint(images[i0], 1);
      if (i1 !== i0 && t > 0.001) paint(images[i1], t);
    }
    function resize() {
      const cw = sticky.clientWidth, chh = sticky.clientHeight;
      canvas.width = Math.round(cw * dpr); canvas.height = Math.round(chh * dpr);
      canvas.style.width = cw + "px"; canvas.style.height = chh + "px";
      computeCover();
      draw(fp * (count - 1));
    }

    let chapter = 0;
    let animating = false;
    let engaged = false;
    let lastStepTime = 0;
    const STEP_COOLDOWN = 1000; // ms between steps; you can advance again after 1s
    let releasedAt = 0;
    const last = STOPS.length - 1;
    const lenis = () => (window as any).__lenis;

    // ---- Sound: procedural warm ambience + soft step tones (default off) ----
    let actx: any = null;
    let master: any = null;
    let pad: { stop: () => void } | null = null;
    let soundOn = false;
    function ensureAudio() {
      if (actx) return;
      const AC = (window as any).AudioContext || (window as any).webkitAudioContext;
      if (!AC) return;
      actx = new AC();
      master = actx.createGain();
      master.gain.value = 0;
      master.connect(actx.destination);
    }
    function startPad() {
      if (!actx || !master || pad) return;
      const out = actx.createGain(); out.gain.value = 0;
      const lp = actx.createBiquadFilter(); lp.type = "lowpass"; lp.frequency.value = 600;
      out.connect(lp); lp.connect(master);
      const oscs = [110, 164.81, 220].map((f) => {
        const o = actx.createOscillator(); o.type = "sine"; o.frequency.value = f;
        const g = actx.createGain(); g.gain.value = 0.32;
        o.connect(g); g.connect(out); o.start(); return o;
      });
      const lfo = actx.createOscillator(); lfo.frequency.value = 0.08;
      const lfoG = actx.createGain(); lfoG.gain.value = 0.16;
      lfo.connect(lfoG); lfoG.connect(out.gain); lfo.start();
      out.gain.setTargetAtTime(0.5, actx.currentTime, 1.4);
      pad = {
        stop: () => {
          out.gain.setTargetAtTime(0, actx.currentTime, 0.5);
          setTimeout(() => { oscs.forEach((o: any) => { try { o.stop(); } catch {} }); try { lfo.stop(); } catch {} }, 700);
        },
      };
    }
    function stopPad() { if (pad) { pad.stop(); pad = null; } }
    function chime(idx: number) {
      if (!soundOn || !actx || !master) return;
      const scale = [261.63, 329.63, 392.0, 440.0, 523.25, 587.33, 659.25];
      const f = scale[Math.min(scale.length - 1, Math.max(0, idx))];
      const o = actx.createOscillator(); o.type = "triangle"; o.frequency.value = f;
      const g = actx.createGain(); const t = actx.currentTime;
      o.connect(g); g.connect(master);
      g.gain.setValueAtTime(0, t);
      g.gain.linearRampToValueAtTime(0.16, t + 0.02);
      g.gain.exponentialRampToValueAtTime(0.0008, t + 0.7);
      o.start(t); o.stop(t + 0.75);
    }
    function setSound(on: boolean) {
      soundOn = on;
      const btn = document.getElementById("filmSound");
      btn?.classList.toggle("is-on", on);
      btn?.setAttribute("aria-pressed", String(on));
      btn?.setAttribute("aria-label", on ? "Geluid uitzetten" : "Geluid aanzetten");
      if (on) {
        ensureAudio();
        if (actx?.state === "suspended") actx.resume();
        if (master) master.gain.setTargetAtTime(0.9, actx.currentTime, 0.3);
        if (engaged) startPad();
      } else {
        stopPad();
        if (master && actx) master.gain.setTargetAtTime(0, actx.currentTime, 0.2);
      }
    }

    function render(p: number) {
      draw(p * (count - 1));
      if (progEl) progEl.style.transform = "scaleX(" + p + ")";
      if (introEl) introEl.style.opacity = String(Math.max(0, 1 - p / 0.05));
      if (ctaEl) ctaEl.style.opacity = String(Math.max(0, Math.min(1, (p - 0.9) / 0.06)));
      if (hintEl) hintEl.style.opacity = p > 0.015 ? "0" : "1";
      caps.forEach((cap) => {
        const at = parseFloat(cap.dataset.at || "-1");
        const d = Math.abs(p - at);
        cap.style.opacity = String(d > 0.08 ? 0 : 1 - d / 0.08);
      });
    }

    function lock() {
      if (engaged) return;
      engaged = true;
      document.documentElement.style.overflow = "hidden";
      lenis()?.stop();
      if (soundOn) startPad();
    }
    function release(toContent: boolean) {
      if (!engaged) return;
      engaged = false;
      releasedAt = performance.now();
      document.documentElement.style.overflow = "";
      lenis()?.start();
      stopPad();
      if (toContent) {
        const y = film.offsetTop + film.offsetHeight;
        const l = lenis();
        if (l) l.scrollTo(y, { duration: 0.9 });
        else window.scrollTo({ top: y, behavior: "smooth" });
      }
    }

    function goTo(target: number) {
      target = Math.max(0, Math.min(last, target));
      if (target === chapter || animating) return;
      animating = true;
      chime(target);
      const obj = { p: fp };
      gsap.to(obj, {
        p: STOPS[target],
        duration: 0.55 + Math.abs(STOPS[target] - fp) * 1.7,
        ease: "power2.inOut",
        onUpdate: () => { fp = obj.p; render(fp); },
        onComplete: () => { fp = STOPS[target]; chapter = target; render(fp); animating = false; },
      });
    }
    function onWheel(e: WheelEvent) {
      if (!engaged) return;
      e.preventDefault(); // swallow all scrolling while the film is engaged
      const dir = e.deltaY > 0 ? 1 : -1;
      if (dir > 0 && chapter >= last) { if (!animating) release(true); return; }
      if (dir < 0 && chapter <= 0) return;
      if (animating) return;
      const now = performance.now();
      if (now - lastStepTime < STEP_COOLDOWN) return; // one step, next allowed after ~1s
      lastStepTime = now;
      goTo(chapter + dir);
    }
    let touchY: number | null = null;
    let touchStepped = false;
    function onTouchStart(e: TouchEvent) { if (engaged) { touchY = e.touches[0].clientY; touchStepped = false; } }
    function onTouchMove(e: TouchEvent) {
      if (!engaged) return;
      e.preventDefault();
      if (animating || touchStepped || touchY == null) return;
      const dy = touchY - e.touches[0].clientY;
      if (Math.abs(dy) < 30) return;
      touchStepped = true; // one step per swipe; next step needs a new touch
      const dir = dy > 0 ? 1 : -1;
      if (dir > 0 && chapter >= last) { release(true); return; }
      if (dir < 0 && chapter <= 0) return;
      goTo(chapter + dir);
    }
    function onTouchEnd() { touchY = null; }
    function onKey(e: KeyboardEvent) {
      if (!engaged) return;
      const nav = ["ArrowDown", "PageDown", " ", "Spacebar", "ArrowUp", "PageUp"].includes(e.key);
      if (e.repeat && nav) { e.preventDefault(); return; } // ignore held-key repeat
      if (e.key === "ArrowDown" || e.key === "PageDown" || e.key === " " || e.key === "Spacebar") {
        if (chapter >= last) { e.preventDefault(); release(true); return; }
        e.preventDefault(); goTo(chapter + 1);
      } else if (e.key === "ArrowUp" || e.key === "PageUp") {
        if (chapter <= 0) return;
        e.preventDefault(); goTo(chapter - 1);
      } else if (e.key === "Escape" || e.key === "End") {
        release(true);
      }
    }
    function onScrollCheck() {
      if (engaged || animating) return;
      if (performance.now() - releasedAt < 1200) return;
      if (window.scrollY <= 1) { chapter = 0; fp = 0; render(0); window.scrollTo(0, 0); lock(); }
    }

    function build() {
      resize();
      render(0);
      try { (history as any).scrollRestoration = "manual"; } catch (e) {}
      window.scrollTo(0, 0);
      lock();
      document.getElementById("filmSound")?.addEventListener("click", () => setSound(!soundOn));
      window.addEventListener("wheel", onWheel, { passive: false });
      window.addEventListener("touchstart", onTouchStart, { passive: true });
      window.addEventListener("touchmove", onTouchMove, { passive: false });
      window.addEventListener("touchend", onTouchEnd, { passive: true });
      window.addEventListener("keydown", onKey);
      window.addEventListener("scroll", onScrollCheck, { passive: true });
      window.addEventListener("resize", resize);
    }

    fetch("/film/frames/manifest.json")
      .then((r) => r.json())
      .then((m) => {
        count = m.count;
        const pad = (n: number) => String(n).padStart(4, "0");
        let loaded = 0, built = false;
        const ready = Math.min(count, 30);
        const done = () => {
          loaded++;
          const frac = Math.min(1, loaded / ready);
          if (barEl) (barEl as HTMLElement).style.transform = "scaleX(" + frac + ")";
          if (pctEl) pctEl.textContent = Math.round(frac * 100) + "%";
          if (!built && loaded >= ready) { built = true; if (loaderEl) loaderEl.classList.add("is-done"); build(); }
        };
        for (let i = 1; i <= count; i++) {
          const img = new Image();
          img.decoding = "async";
          img.onload = done; img.onerror = done;
          img.src = "/film/frames/f" + pad(i) + ".jpg";
          images[i - 1] = img;
        }
      })
      .catch(() => { document.documentElement.style.overflow = ""; if (film) film.style.display = "none"; if (fallback) fallback.style.display = "block"; });
  }

  if (document.readyState !== "loading") setupFilm();
  else document.addEventListener("DOMContentLoaded", setupFilm);
</script>
