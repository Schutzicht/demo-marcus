---
// Subtle Moroccan zellige (8-point star) tile motif. Use as a faint texture.
interface Props { class?: string; color?: string; opacity?: number }
const { class: cls = "", color = "#bd5a35", opacity = 0.1 } = Astro.props;
const id = "zel-" + Math.random().toString(36).slice(2, 8);
---
<svg class={cls} aria-hidden="true" style={`opacity:${opacity}`} width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
  <defs>
    <pattern id={id} width="80" height="80" patternUnits="userSpaceOnUse" patternTransform="rotate(0)">
      <g fill="none" stroke={color} stroke-width="1.1">
        <path d="M40 8 L48 24 L64 24 L52 36 L58 52 L40 44 L22 52 L28 36 L16 24 L32 24 Z" />
        <circle cx="40" cy="40" r="4" />
        <path d="M0 40 L16 40 M64 40 L80 40 M40 0 L40 16 M40 64 L40 80" />
      </g>
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill={`url(#${id})`} />
</svg>
