---
import "../styles/global.css";
import { SITE } from "../data/site";
import Logo from "../components/Logo.astro";

interface Props {
  title?: string;
  description?: string;
  active?: string;
}
const {
  title = `${SITE.name} — ${SITE.tagline}`,
  description = SITE.intro,
  active = "",
} = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/img/scene-1.webp" />
    <meta name="theme-color" content="#20130a" />
  </head>
  <body>
    <!-- Floating pill nav -->
    <header class="pointer-events-none fixed inset-x-0 top-3 z-50 flex justify-center px-3 sm:top-5">
      <nav
        class="pointer-events-auto flex w-full max-w-3xl items-center justify-between gap-3 rounded-full border border-cream/10 bg-espresso/85 px-4 py-2.5 text-cream backdrop-blur-md sm:px-6"
        style="box-shadow: 0 20px 50px -24px rgba(20,11,5,.7)"
      >
        <a href="/" class="press flex items-center gap-2" aria-label={SITE.name}>
          <span class="font-display text-xl font-semibold tracking-tight sm:text-2xl">{SITE.wordmark}</span>
          <span class="hidden h-1 w-1 rounded-full bg-saffron sm:block"></span>
        </a>
        <div class="hidden items-center gap-7 md:flex">
          {
            SITE.nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "underline-grow text-[0.82rem] font-medium tracking-wide text-cream/85 transition-colors hover:text-cream",
                  active === item.href && "text-cream",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </div>
        <button
          id="navToggle"
          class="press flex h-9 w-9 items-center justify-center rounded-full bg-cream/10 md:hidden"
          aria-label="Menu"
          aria-expanded="false"
        >
          <span class="relative block h-3 w-4">
            <span class="absolute left-0 top-0 h-[1.5px] w-full bg-cream transition-transform"></span>
            <span class="absolute bottom-0 left-0 h-[1.5px] w-full bg-cream transition-transform"></span>
          </span>
        </button>
      </nav>
    </header>

    <!-- Mobile overlay menu -->
    <div
      id="navOverlay"
      class="fixed inset-0 z-40 flex translate-y-[-100%] flex-col justify-center bg-espresso px-8 text-cream transition-transform duration-500 [transition-timing-function:cubic-bezier(0.16,1,0.3,1)] md:hidden"
    >
      <div class="grain absolute inset-0 opacity-100"></div>
      <nav class="relative flex flex-col gap-2">
        {
          SITE.nav.map((item, i) => (
            <a
              href={item.href}
              class="font-display text-5xl font-semibold tracking-tight text-cream/90"
              style={`opacity:0;transform:translateY(20px);transition:all .5s cubic-bezier(0.16,1,0.3,1) ${i * 0.06}s`}
              data-nav-item
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="relative mt-12 flex flex-col gap-1 text-cream/60">
        <a href={SITE.contact.phoneHref} class="underline-grow w-fit">{SITE.contact.phone}</a>
        <a href={SITE.socials.instagram} target="_blank" rel="noopener" class="underline-grow w-fit"
          >{SITE.socials.instagramHandle}</a
        >
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative overflow-hidden bg-ink text-cream">
      <div class="grain absolute inset-0"></div>
      <div class="relative mx-auto max-w-7xl px-6 pb-10 pt-20 sm:px-10">
        <div class="grid gap-12 md:grid-cols-[1.3fr_1fr_1fr]">
          <div>
            <Logo tone="line" size={74} class="mb-6 text-cream/90" />
            <p class="eyebrow text-saffron">{SITE.tagline}</p>
            <p class="mt-5 max-w-sm font-display text-2xl leading-tight text-cream/90">
              {SITE.intro}
            </p>
            <div class="mt-7 flex gap-3">
              <a href="/reserveren" class="press rounded-full bg-clay px-6 py-3 text-sm font-semibold text-cream">Reserveren</a>
              <a
                href={SITE.socials.instagram}
                target="_blank"
                rel="noopener"
                class="press rounded-full border border-cream/25 px-6 py-3 text-sm font-semibold text-cream/90">Instagram</a
              >
            </div>
          </div>

          <div>
            <p class="eyebrow text-cream/40">Pagina's</p>
            <ul class="mt-5 space-y-2.5 text-cream/80">
              <li><a href="/" class="underline-grow">Home</a></li>
              {SITE.nav.map((i) => <li><a href={i.href} class="underline-grow">{i.label}</a></li>)}
            </ul>
            <p class="eyebrow mt-8 text-cream/40">Vind ons</p>
            <p class="mt-4 leading-relaxed text-cream/80">
              {SITE.address.street}<br />
              {SITE.address.zip} {SITE.address.city}
            </p>
            <div class="mt-3 flex flex-col gap-1 text-cream/80">
              <a href={SITE.contact.phoneHref} class="underline-grow w-fit">{SITE.contact.phone}</a>
              <a href={SITE.contact.emailHref} class="underline-grow w-fit">{SITE.contact.email}</a>
            </div>
          </div>

          <div>
            <p class="eyebrow text-cream/40">Openingstijden</p>
            <ul class="mt-5 space-y-1.5 text-sm">
              {
                SITE.hours.map((h) => (
                  <li class="flex justify-between gap-4 border-b border-cream/10 pb-1.5">
                    <span class="text-cream/70">{h.day}</span>
                    <span class:list={[h.closed ? "text-cream/35" : "text-cream/90"]}>{h.time}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div class="relative mt-16">
          <div class="pointer-events-none select-none text-center font-display font-semibold leading-none tracking-tight text-cream/[0.07]" style="font-size:clamp(4rem,22vw,18rem)">
            {SITE.wordmark}
          </div>
        </div>

        <div class="mt-6 flex flex-col items-center justify-between gap-4 border-t border-cream/10 pt-6 text-xs text-cream/40 sm:flex-row">
          <p>© {new Date().getFullYear()} {SITE.legal} · {SITE.address.city}</p>
          <div class="flex items-center gap-4">
            <a href="/beheer" class="underline-grow text-cream/35 hover:text-cream/70">Beheer</a>
            <a href="https://agensea.nl" target="_blank" rel="noopener" class="underline-grow">Demo door Agensea</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Floating dual CTA -->
    <div class="pointer-events-none fixed inset-x-0 bottom-4 z-40 flex justify-center px-3" id="floatCta">
      <div class="pointer-events-auto flex gap-2 rounded-full border border-ink/10 bg-cream/85 p-1.5 backdrop-blur-md" style="box-shadow: 0 18px 50px -20px rgba(20,11,5,.5)">
        <a href="/reserveren" class="press rounded-full px-5 py-2.5 text-sm font-semibold text-ink/80 transition-colors hover:text-ink sm:px-7"
          >Reserveren</a
        >
        <a href="/menu" class="press rounded-full bg-ink px-5 py-2.5 text-sm font-semibold text-cream sm:px-7">Bekijk menu</a>
      </div>
    </div>

    <div class="curtain" aria-hidden="true"><span class="curtain__word">{SITE.wordmark}</span></div>

    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // ---- Lenis smooth scroll, synced with GSAP ----
      if (!reduce) {
        const lenis = new Lenis({ duration: 1.1, smoothWheel: true });
        lenis.on("scroll", ScrollTrigger.update);
        gsap.ticker.add((time) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
        (window as any).__lenis = lenis;
      }

      // ---- Scroll reveal ----
      const reveals = document.querySelectorAll("[data-reveal]");
      if (reveals.length) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        reveals.forEach((el) => io.observe(el));
      }

      // ---- Mobile nav ----
      const toggle = document.getElementById("navToggle");
      const overlay = document.getElementById("navOverlay");
      const items = overlay?.querySelectorAll("[data-nav-item]");
      let open = false;
      const setOpen = (v: boolean) => {
        open = v;
        toggle?.setAttribute("aria-expanded", String(v));
        if (overlay) overlay.style.transform = v ? "translateY(0)" : "translateY(-100%)";
        items?.forEach((el) => {
          (el as HTMLElement).style.opacity = v ? "1" : "0";
          (el as HTMLElement).style.transform = v ? "translateY(0)" : "translateY(20px)";
        });
        document.documentElement.style.overflow = v ? "hidden" : "";
      };
      toggle?.addEventListener("click", () => setOpen(!open));
      overlay?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));

      // ---- Hide floating CTA when footer is in view ----
      const cta = document.getElementById("floatCta");
      const footer = document.querySelector("footer");
      if (cta && footer) {
        const fo = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              cta.style.opacity = e.isIntersecting ? "0" : "1";
              cta.style.transform = e.isIntersecting ? "translateY(120%)" : "translateY(0)";
            });
          },
          { threshold: 0.06 }
        );
        fo.observe(footer);
        cta.style.transition = "opacity .4s ease, transform .5s cubic-bezier(0.16,1,0.3,1)";
      }

      // ---- Page-transition curtain ----
      const curtain = document.querySelector<HTMLElement>(".curtain");
      const reduceCurtain = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (curtain && !reduceCurtain) {
        // Entering: if we arrived via a curtain navigation, sweep it away upward.
        if (sessionStorage.getItem("marcus_curtain")) {
          sessionStorage.removeItem("marcus_curtain");
          curtain.style.transition = "none";
          curtain.style.transform = "translateY(0)";
          requestAnimationFrame(() =>
            requestAnimationFrame(() => {
              curtain.style.transition = "";
              curtain.style.transform = "translateY(-100%)";
              window.setTimeout(() => {
                curtain.style.transition = "none";
                curtain.style.transform = "translateY(100%)";
              }, 640);
            })
          );
        }
        // Leaving: cover the screen, then navigate.
        document.addEventListener("click", (e) => {
          const a = (e.target as HTMLElement).closest?.("a[href]") as HTMLAnchorElement | null;
          if (!a) return;
          const href = a.getAttribute("href") || "";
          if (!href || a.target === "_blank" || a.hasAttribute("download")) return;
          if (href.startsWith("#") || href.startsWith("mailto:") || href.startsWith("tel:")) return;
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
          let url: URL;
          try { url = new URL(href, location.href); } catch { return; }
          if (url.origin !== location.origin || url.pathname === location.pathname) return;
          e.preventDefault();
          sessionStorage.setItem("marcus_curtain", "1");
          curtain.style.transition = "";
          curtain.style.transform = "translateY(0)";
          window.setTimeout(() => { location.href = url.href; }, 470);
        });
      }
    </script>
  </body>
</html>
