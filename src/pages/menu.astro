---
import Base from "../layouts/Base.astro";
import Zellige from "../components/Zellige.astro";
import { MENU, SIGNATURES } from "../data/site";
---

<Base title="Menu — Koffiebar Marcus" active="/menu">
  <!-- header -->
  <header class="relative overflow-hidden bg-espresso pt-32 text-cream grain sm:pt-40">
    <Zellige class="pointer-events-none absolute inset-0" color="#e0a52e" opacity={0.06} />
    <div class="relative mx-auto max-w-7xl px-6 pb-16 sm:px-10">
      <p class="eyebrow text-saffron" data-reveal>De kaart</p>
      <h1 class="mt-4 text-mega font-semibold" data-reveal>Menu</h1>
      <p class="mt-6 max-w-md text-lg text-cream/70" data-reveal data-reveal-delay="1">
        Alles huisgemaakt. Prijzen zijn richtprijzen voor deze demo en passen we zo aan.
      </p>
    </div>
  </header>

  <!-- category quick-nav -->
  <nav class="sticky top-[4.7rem] z-30 border-y border-ink/10 bg-cream/90 backdrop-blur-md sm:top-[5.4rem]">
    <div class="mx-auto flex max-w-7xl gap-2 overflow-x-auto px-6 py-3 sm:px-10">
      {
        MENU.map((c) => (
          <a href={`#${c.id}`} class="press shrink-0 rounded-full border border-ink/15 px-4 py-1.5 text-sm font-medium text-ink/70 transition-colors hover:bg-ink hover:text-cream">
            {c.title}
          </a>
        ))
      }
    </div>
  </nav>

  <!-- categories -->
  <div class="mx-auto max-w-7xl px-6 py-20 sm:px-10">
    {
      MENU.map((cat, ci) => (
        <section id={cat.id} class="scroll-mt-40 border-t border-ink/10 py-14 first:border-t-0 first:pt-4">
          <div class="grid gap-8 md:grid-cols-[0.8fr_1.2fr]">
            <div data-reveal>
              <span class="font-display text-7xl text-clay/20">0{ci + 1}</span>
              <h2 class="-mt-6 text-big font-semibold text-ink">{cat.title}</h2>
              <p class="mt-3 max-w-xs text-ink/60">{cat.blurb}</p>
            </div>
            <ul class="divide-y divide-ink/10">
              {cat.items.map((item, i) => (
                <li class="flex items-baseline gap-4 py-4" data-reveal data-reveal-delay={(i % 3) + 1}>
                  <div class="min-w-0">
                    <h3 class="flex flex-wrap items-center gap-2 font-display text-xl font-medium text-ink">
                      {item.name}
                      {item.tag === "huis" && <span class="rounded-full bg-clay/10 px-2 py-0.5 text-[0.62rem] font-semibold uppercase tracking-wide text-clay">huisgemaakt</span>}
                      {item.tag === "deel" && <span class="rounded-full bg-zellige/10 px-2 py-0.5 text-[0.62rem] font-semibold uppercase tracking-wide text-zellige">om te delen</span>}
                    </h3>
                    {item.desc && <p class="mt-0.5 text-sm text-ink/55">{item.desc}</p>}
                  </div>
                  <span class="mx-2 grow border-b border-dotted border-ink/25"></span>
                  <span class="shrink-0 font-display text-lg text-ink">€ {item.price}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>
      ))
    }
  </div>

  <!-- signatures callout -->
  <section class="relative overflow-hidden bg-clay py-20 text-cream">
    <div class="mx-auto max-w-7xl px-6 text-center sm:px-10">
      <p class="eyebrow text-cream/70" data-reveal>Niet te missen</p>
      <h2 class="mt-4 text-giant font-semibold" data-reveal>Vraag naar de signatures</h2>
      <div class="mt-10 flex flex-wrap justify-center gap-x-8 gap-y-3" data-reveal data-reveal-delay="1">
        {SIGNATURES.map((s) => <span class="font-display text-2xl text-cream/90">{s.name}</span>)}
      </div>
      <a href="/reserveren" class="press mt-10 inline-block rounded-full bg-cream px-8 py-4 text-sm font-semibold text-ink">Reserveer een tafel</a>
    </div>
  </section>
</Base>
