---
import Base from "../layouts/Base.astro";
import ScrollFilm from "../components/ScrollFilm.astro";
import Zellige from "../components/Zellige.astro";
import { SITE, SIGNATURES, STORY, REVIEWS, FEED, HIGHTEA } from "../data/site";

const marquee = ["Koffie", "Thee", "Huisgemaakt", "Mezze", "High Tea", "Zoet", "Muntthee"];
---

<Base active="">
  <!-- The scroll-film -->
  <ScrollFilm />

  <!-- Homemade intro -->
  <section class="relative overflow-hidden bg-cream">
    <Zellige class="pointer-events-none absolute -right-20 -top-20 h-80 w-80 rotate-12" color="#bd5a35" opacity={0.08} />
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 py-24 sm:px-10 md:grid-cols-2 md:py-32">
      <div data-reveal>
        <p class="eyebrow text-clay">Alles #homemade</p>
        <h2 class="mt-5 text-big font-semibold text-ink">
          Alles wat je proeft, is hier <span class="text-clay">gemaakt</span>.
        </h2>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-ink/70">
          Geen kant-en-klaar, geen halve verhalen. We branden, bakken en brouwen zelf, elke ochtend opnieuw. Dat is
          de hele filosofie van Marcus.
        </p>
        <a
          href="/menu"
          class="press underline-grow mt-8 inline-flex items-center gap-2 rounded-full bg-ink px-7 py-3.5 text-sm font-semibold text-cream"
        >
          Bekijk de kaart
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div data-reveal data-reveal-delay="1" class="relative">
        <div class="arch-soft relative aspect-[4/5] overflow-hidden bg-sand grain" style="box-shadow: var(--shadow-warm)">
          <img src="/img/huisgemaakt.webp" alt="Huisgemaakte taart" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="absolute -bottom-5 -left-5 rounded-2xl bg-saffron px-5 py-3 font-display text-ink shadow-lg">
          <span class="text-2xl font-semibold leading-none">Vers</span>
          <span class="block text-xs tracking-wide">uit eigen oven</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Signatures (dark) -->
  <section class="relative overflow-hidden bg-espresso text-cream grain">
    <div class="mx-auto grid max-w-7xl gap-14 px-6 py-24 sm:px-10 md:grid-cols-[0.9fr_1.1fr] md:py-32">
      <div data-reveal class="relative">
        <div class="arch relative mx-auto aspect-[3/4] max-w-sm overflow-hidden bg-zellige-deep" style="box-shadow: var(--shadow-warm)">
          <img src="/img/signature.webp" alt="Signature drink van Marcus" class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
      <div>
        <p class="eyebrow text-saffron" data-reveal>Onze klassiekers</p>
        <h2 class="mt-5 text-big font-semibold" data-reveal>De signatures</h2>
        <p class="mt-4 max-w-md text-cream/65" data-reveal>
          Bedacht achter de bar, nergens anders zo te krijgen.
        </p>
        <ul class="mt-10 divide-y divide-cream/10">
          {
            SIGNATURES.map((s, i) => (
              <li class="flex items-baseline justify-between gap-6 py-5" data-reveal data-reveal-delay={(i % 3) + 1}>
                <div>
                  <h3 class="font-display text-2xl font-semibold text-cream">{s.name}</h3>
                  <p class="mt-1 text-sm text-cream/55">{s.note}</p>
                </div>
                <span class="shrink-0 font-display text-xl text-saffron">€ {s.price}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Marquee band -->
  <section class="relative overflow-hidden border-y border-ink/10 bg-clay py-5 text-cream">
    <div class="marquee-track flex w-max items-center gap-8 whitespace-nowrap will-change-transform">
      {
        Array.from({ length: 3 }).map(() =>
          marquee.map((w) => (
            <span class="flex items-center gap-8">
              <span class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">{w}</span>
              <svg width="20" height="20" viewBox="0 0 24 24" class="text-saffron"><path d="M12 2l2.4 7.4H22l-6 4.4 2.3 7.4-6.3-4.6L5.7 21l2.3-7.4-6-4.4h7.6z" fill="currentColor"/></svg>
            </span>
          ))
        )
      }
    </div>
  </section>

  <!-- Story teaser -->
  <section class="relative overflow-hidden bg-cream">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 py-24 sm:px-10 md:grid-cols-2 md:py-32">
      <div data-reveal class="relative order-2 md:order-1">
        <div class="arch-key relative aspect-[4/5] overflow-hidden bg-sand grain" style="box-shadow: var(--shadow-warm)">
          <img src={STORY.image} alt="De eigenaar van Marcus" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <Zellige class="pointer-events-none absolute -bottom-10 -right-10 h-44 w-44" color="#1f5e54" opacity={0.18} />
      </div>
      <div class="order-1 md:order-2" data-reveal data-reveal-delay="1">
        <p class="eyebrow text-zellige">{STORY.eyebrow}</p>
        <h2 class="mt-5 text-big font-semibold text-ink">{STORY.title}</h2>
        {STORY.body.map((p) => <p class="mt-5 max-w-md text-lg leading-relaxed text-ink/70">{p}</p>)}
        <p class="mt-6 font-display text-2xl text-clay">{STORY.signature}</p>
        <a href="/sfeer" class="press underline-grow mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ink">
          Ons verhaal
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- High tea feature -->
  <section class="relative">
    <div class="relative mx-auto max-w-7xl px-6 sm:px-10">
      <div class="vignette grain relative flex min-h-[60vh] items-end overflow-hidden rounded-[2rem] bg-ink" data-reveal>
        <img src="/img/hightea.webp" alt="High tea bij Marcus" class="absolute inset-0 h-full w-full object-cover opacity-90" loading="lazy" />
        <div class="relative z-10 p-8 sm:p-14">
          <p class="eyebrow text-saffron">Reserveer je tafel</p>
          <h2 class="mt-4 text-giant font-semibold text-cream">High tea</h2>
          <p class="mt-4 max-w-md text-lg text-cream/85">{HIGHTEA.blurb}</p>
          <div class="mt-7 flex flex-wrap items-center gap-5">
            <a href="/high-tea" class="press rounded-full bg-cream px-7 py-3.5 text-sm font-semibold text-ink">Meer over de high tea</a>
            <span class="font-display text-2xl text-cream">€ {HIGHTEA.price} <span class="text-base text-cream/60">{HIGHTEA.per}</span></span>
          </div>
        </div>
      </div>
    </div>
    <div class="py-12"></div>
  </section>

  <!-- Reviews -->
  <section class="relative overflow-hidden bg-plaster">
    <div class="mx-auto max-w-7xl px-6 py-24 sm:px-10">
      <div class="flex items-end justify-between gap-6" data-reveal>
        <div>
          <p class="eyebrow text-clay">Wat gasten zeggen</p>
          <h2 class="mt-4 text-big font-semibold text-ink">Vijf sterren, vol</h2>
        </div>
        <div class="hidden items-center gap-1 sm:flex">
          {Array.from({ length: 5 }).map(() => <svg width="22" height="22" viewBox="0 0 24 24" class="text-saffron"><path d="M12 2l2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z" fill="currentColor"/></svg>)}
        </div>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          REVIEWS.map((r, i) => (
            <figure class="lift flex flex-col rounded-3xl border border-ink/10 bg-cream p-7" data-reveal data-reveal-delay={i + 1}>
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map(() => <svg width="16" height="16" viewBox="0 0 24 24" class="text-saffron"><path d="M12 2l2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z" fill="currentColor"/></svg>)}
              </div>
              <blockquote class="mt-5 grow font-display text-xl leading-snug text-ink/90">"{r.quote}"</blockquote>
              <figcaption class="mt-6 text-sm">
                <span class="font-semibold text-ink">{r.name}</span>
                <span class="text-ink/45"> · {r.meta}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Instagram feed -->
  <section class="relative overflow-hidden bg-cream">
    <div class="mx-auto max-w-7xl px-6 py-24 sm:px-10">
      <div class="flex flex-col items-center text-center" data-reveal>
        <p class="eyebrow text-clay">Volg ons</p>
        <h2 class="mt-4 text-giant font-semibold text-ink">{SITE.socials.instagramHandle}</h2>
        <a
          href={SITE.socials.instagram}
          target="_blank"
          rel="noopener"
          class="press mt-7 inline-flex items-center gap-2 rounded-full border border-ink/20 px-7 py-3.5 text-sm font-semibold text-ink"
        >
          Volg op Instagram
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg>
        </a>
      </div>
      <div class="mt-12 grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-4">
        {
          FEED.map((src, i) => (
            <a href={SITE.socials.instagram} target="_blank" rel="noopener" class="lift group relative aspect-square overflow-hidden rounded-2xl bg-sand" data-reveal data-reveal-delay={(i % 4) + 1}>
              <img src={src} alt="Instagram van Marcus" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              <span class="absolute inset-0 bg-ink/0 transition-colors group-hover:bg-ink/15"></span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
