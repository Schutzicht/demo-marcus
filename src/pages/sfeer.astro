---
import Base from "../layouts/Base.astro";
import Zellige from "../components/Zellige.astro";
import { STORY, SITE } from "../data/site";

const values = [
  { t: "Alles huisgemaakt", d: "Van branding tot taart, niets verlaat de keuken zonder dat het hier is gemaakt." },
  { t: "Marokkaanse keuken", d: "Mezze, msemen en kruiden van het zuiden, naast je dagelijkse cappuccino." },
  { t: "Eén eigenaar", d: "Eén gezicht, één visie. Je wordt ontvangen alsof je thuiskomt." },
];
const gallery = ["/img/interior-arch.webp", "/img/sfeer-choco.webp", "/img/tea-mint.webp", "/img/scene-4.webp", "/img/scene-5.webp", "/img/scene-3.webp"];
---

<Base title="Sfeer & verhaal — Koffiebar Marcus" active="/sfeer">
  <!-- hero -->
  <header class="vignette grain relative flex min-h-[80vh] items-end overflow-hidden bg-ink">
    <img src="/img/interieur.webp" alt="Het interieur van Marcus" class="absolute inset-0 h-full w-full object-cover" />
    <div class="relative z-10 mx-auto w-full max-w-7xl px-6 pb-20 sm:px-10">
      <p class="eyebrow text-saffron" data-reveal>{SITE.address.city}</p>
      <h1 class="mt-4 text-mega font-semibold text-cream" data-reveal>Sfeer<br />& verhaal</h1>
    </div>
  </header>

  <!-- story -->
  <section class="relative overflow-hidden bg-cream">
    <div class="mx-auto grid max-w-7xl items-center gap-14 px-6 py-24 sm:px-10 md:grid-cols-2 md:py-32">
      <div data-reveal class="relative">
        <div class="arch-key relative aspect-[4/5] overflow-hidden bg-sand grain" style="box-shadow: var(--shadow-warm)">
          <img src={STORY.image} alt="De eigenaar" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <Zellige class="pointer-events-none absolute -right-12 -top-12 h-48 w-48" color="#1f5e54" opacity={0.16} />
      </div>
      <div data-reveal data-reveal-delay="1">
        <p class="eyebrow text-zellige">{STORY.eyebrow}</p>
        <h2 class="mt-5 text-big font-semibold text-ink">{STORY.title}</h2>
        {STORY.body.map((p) => <p class="mt-5 max-w-md text-lg leading-relaxed text-ink/70">{p}</p>)}
        <p class="mt-8 max-w-md text-lg leading-relaxed text-ink/70">
          Binnen voel je de Marokkaanse hand: warme aardetinten, zellige-tegels, brass en zacht licht. Het soort plek
          waar je per ongeluk twee uur blijft hangen.
        </p>
        <p class="mt-6 font-display text-2xl text-clay">{STORY.signature}</p>
      </div>
    </div>
  </section>

  <!-- values -->
  <section class="bg-espresso py-24 text-cream">
    <div class="mx-auto max-w-7xl px-6 sm:px-10">
      <div class="grid gap-10 md:grid-cols-3">
        {
          values.map((v, i) => (
            <div data-reveal data-reveal-delay={i + 1}>
              <span class="font-display text-5xl text-saffron/40">0{i + 1}</span>
              <h3 class="mt-3 font-display text-2xl font-semibold">{v.t}</h3>
              <p class="mt-2 text-cream/65">{v.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- gallery -->
  <section class="bg-cream py-20">
    <div class="mx-auto max-w-7xl px-6 sm:px-10">
      <div class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-4">
        {
          gallery.map((src, i) => (
            <div class:list={["lift relative overflow-hidden rounded-2xl bg-sand", i % 2 === 0 ? "aspect-[3/4]" : "aspect-[3/4] md:mt-10"]} data-reveal data-reveal-delay={(i % 4) + 1}>
              <img src={src} alt="Sfeerbeeld" class="h-full w-full object-cover" loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
